---
import ColorStripe from "../components/ColorStripe.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  wide?: boolean;
}

const SITE_NAME = "Sune Lehmann";
const SITE_SUBTITLE = "Intermittent Updates";
const DEFAULT_DESCRIPTION =
  "Sune Lehmann — networks, complexity, and the occasional blog post.";
const DEFAULT_OG_IMAGE = "/og-image.jpg";

// GoatCounter analytics. Empty string disables. See ANALYTICS.md for setup.
const GOATCOUNTER_CODE = "suneman";

const {
  title,
  description = DEFAULT_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  noIndex = false,
  wide = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE_NAME}` : `${SITE_NAME}: ${SITE_SUBTITLE}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

const navLinks = [
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
  { href: "/featured-publications", label: "Publications" },
  { href: "/cv", label: "CV" },
];

const menuLinks = [
  { href: "/people", label: "People" },
  { href: "/videos", label: "Videos" },
  { href: "/podcasts", label: "Podcasts" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title ?? `${SITE_NAME}: ${SITE_SUBTITLE}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_NAME}: ${SITE_SUBTITLE}`}
      href="/rss.xml"
    />
  </head>

  <body>
    <svg
      class="icon-sprite"
      width="0"
      height="0"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <symbol id="i-site" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20"></path>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </symbol>
        <symbol id="i-scholar" viewBox="0 0 24 24">
          <path fill="currentColor" d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"></path>
        </symbol>
        <symbol id="i-linkedin" viewBox="0 0 24 24">
          <path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </symbol>
        <symbol id="i-github" viewBox="0 0 24 24">
          <path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
        </symbol>
        <symbol id="i-bluesky" viewBox="0 0 24 24">
          <path fill="currentColor" d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"></path>
        </symbol>
        <symbol id="i-orcid" viewBox="0 0 24 24">
          <path fill="currentColor" d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"></path>
        </symbol>
      </defs>
    </svg>
    <header class="site-header">
      <a class="site-title" href="/">
        <span class="site-title__name">{SITE_NAME}</span><span class="site-title__sep" aria-hidden="true">: </span><span class="site-title__subtitle">{SITE_SUBTITLE}</span>
      </a>
      <nav class="site-nav" aria-label="Main">
        <ul class="site-nav__primary">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={currentPath === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="site-menu-wrap">
          <button
            type="button"
            class="site-menu-toggle"
            aria-controls="site-menu"
            aria-expanded="false"
            aria-haspopup="menu"
            aria-label="Open menu"
          >
            <span class="site-menu-toggle__bar" aria-hidden="true"></span>
            <span class="site-menu-toggle__bar" aria-hidden="true"></span>
            <span class="site-menu-toggle__bar" aria-hidden="true"></span>
          </button>
          <ul id="site-menu" class="site-menu" role="menu" hidden>
            {navLinks.map((link) => (
              <li class="site-menu__item--primary" role="none">
                <a
                  href={link.href}
                  role="menuitem"
                  aria-current={currentPath === link.href ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
            <li class="site-menu__divider" role="separator" aria-hidden="true"></li>
            {menuLinks.map((link) => (
              <li role="none">
                <a
                  href={link.href}
                  role="menuitem"
                  aria-current={currentPath === link.href ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </header>

    <main class:list={["site-main", wide && "site-main--wide"]}>
      <slot />
    </main>

    <footer class="site-footer">
      <ColorStripe thickness="4px" />

      <p class="site-footer__note">
        AI declaration: All blog posts were painstakingly <em class="site-footer__hl">typed on a keyboard</em> 
		by yours truly. The static site (including the portraits) was generated by AI from a private database 
		of CV facts and other good stuff. Images are from many sources, incl gen-AI.
        &copy; {new Date().getFullYear()} Sune Lehmann.
      </p>
    </footer>

    <script is:inline>
      (function () {
        const toggle = document.querySelector(".site-menu-toggle");
        const panel = document.getElementById("site-menu");
        if (!toggle || !panel) return;

        const open = () => {
          panel.hidden = false;
          toggle.setAttribute("aria-expanded", "true");
          toggle.setAttribute("aria-label", "Close menu");
        };
        const close = () => {
          panel.hidden = true;
          toggle.setAttribute("aria-expanded", "false");
          toggle.setAttribute("aria-label", "Open menu");
        };

        toggle.addEventListener("click", (event) => {
          event.stopPropagation();
          if (toggle.getAttribute("aria-expanded") === "true") {
            close();
          } else {
            open();
          }
        });

        document.addEventListener("click", (event) => {
          if (panel.hidden) return;
          if (panel.contains(event.target) || toggle.contains(event.target)) return;
          close();
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && !panel.hidden) {
            close();
            toggle.focus();
          }
        });
      })();
    </script>

    {GOATCOUNTER_CODE && (
      <script
        is:inline
        data-goatcounter={`https://${GOATCOUNTER_CODE}.goatcounter.com/count`}
        async
        src="https://gc.zgo.at/count.js"
      ></script>
    )}

    <style is:global>
      /* ---------- tokens ---------- */
      :root {
        --bg: #f6f2ea;
        --fg: #1a1814;
        --fg-muted: #6b655d;
        --rule: #e3ddd0;

        /* Six-color earth palette — bolder, saturated, sweeping warm→cool→warm
           (sienna → clay → mustard → olive → teal → oxblood). All still sit
           on the warm side; --accent is the primary. */
        --accent: #b8451e;          /* burnt sienna */
        --accent-clay: #d96a2c;     /* terracotta clay */
        --accent-mustard: #e8b126;  /* mustard ochre */
        --accent-olive: #7e8d20;    /* olive */
        --accent-teal: #107078;     /* deep teal */
        --accent-oxblood: #992c44;  /* oxblood wine */

        --serif: "Fraunces", "Palatino", Georgia, serif;
        --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;

        --measure: 36rem;
        --gutter: clamp(1rem, 4vw, 2.5rem);

        /* Six-band gradient mirroring <ColorStripe />, for use on hr,
           pseudo-elements, and other places where mounting the component
           is awkward. Hard stops keep the bands equal width. */
        --color-stripe-gradient: linear-gradient(
          to right,
          var(--accent) 0 16.6667%,
          var(--accent-clay) 16.6667% 33.3333%,
          var(--accent-mustard) 33.3333% 50%,
          var(--accent-olive) 50% 66.6667%,
          var(--accent-teal) 66.6667% 83.3333%,
          var(--accent-oxblood) 83.3333% 100%
        );
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f0e0c;
          --fg: #ede6d6;
          --fg-muted: #8a8377;
          --accent: #d4923a; /* placeholder; final amber-vs-teal pending */
          --rule: #1f1d18;
        }
      }

      /* ---------- reset ---------- */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
        font-size: 18px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }

      a:hover {
        text-decoration-thickness: 2px;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--serif);
        font-weight: 600;
      }

      h1 {
        line-height: 1.1;
        letter-spacing: -0.015em;
        font-variation-settings: "opsz" 96;
      }

      h2 {
        line-height: 1.25;
        letter-spacing: 0;
        font-variation-settings: "opsz" 36;
      }

      h3,
      h4 {
        line-height: 1.3;
        letter-spacing: 0.005em;
        font-variation-settings: "opsz" 18;
      }

      /* ---------- header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 0.75rem var(--gutter);
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        backdrop-filter: saturate(140%) blur(8px);
        border-bottom: 1px solid var(--rule);
      }

      .site-title {
        font-family: var(--serif);
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        font-weight: 600;
        text-decoration: none;
        color: var(--fg);
        white-space: nowrap;
        letter-spacing: -0.015em;
        font-variation-settings: "opsz" 72;
        line-height: 1.1;
      }

      .site-title__sep {
        color: var(--fg-muted);
      }

      .site-title__subtitle {
        color: var(--fg-muted);
        font-style: italic;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
      }

      .site-nav__primary {
        display: flex;
        gap: 1.25rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .site-nav a {
        color: var(--fg);
        text-decoration: none;
        font-size: 1.05rem;
        font-weight: 600;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        color: var(--accent);
      }

      .site-menu-wrap {
        position: relative;
      }

      .site-menu-toggle {
        display: inline-flex;
        flex-direction: column;
        justify-content: center;
        align-self: center;
        gap: 5px;
        width: 1.84rem;
        height: 1.68rem; /* matches nav text line-box; transform nudges to optical center */
        padding: 0;
        line-height: 1;
        background: transparent;
        border: 0;
        cursor: pointer;
        color: var(--fg);
        transform: translateY(-5px);
      }

      .site-menu-toggle:hover,
      .site-menu-toggle[aria-expanded="true"] {
        color: var(--accent);
      }

      .site-menu-toggle__bar {
        display: block;
        height: 2px;
        background: currentColor;
        border-radius: 2px;
      }

      .site-menu {
        position: absolute;
        top: calc(100% + 0.6rem);
        right: 0;
        min-width: 9rem;
        margin: 0;
        padding: 0.5rem 0;
        list-style: none;
        background: var(--bg);
        border: 1px solid var(--rule);
        border-radius: 4px;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
        z-index: 20;
      }

      .site-menu[hidden] {
        display: none;
      }

      .site-menu li {
        margin: 0;
      }

      .site-menu a {
        display: block;
        padding: 0.4rem 1rem;
        white-space: nowrap;
      }

      .site-menu a:hover {
        background: color-mix(in srgb, var(--accent) 8%, transparent);
      }

      .site-menu__divider {
        height: 1px;
        background: var(--rule);
        margin: 0.4rem 0;
        padding: 0;
        border: 0;
        list-style: none;
      }

      /* Mobile: hide visible nav links and wordmark suffix; the hamburger
         panel grows to include all primary links. */
      @media (max-width: 600px) {
        .site-title__sep,
        .site-title__subtitle {
          display: none;
        }
        .site-nav__primary {
          display: none;
        }
      }

      @media (min-width: 601px) {
        .site-menu__item--primary,
        .site-menu__divider {
          display: none;
        }
      }

      /* ---------- video embeds (YouTube via remark-embeds, Vimeo + Panopto inline) ---------- */
      .embed--youtube,
      .embed--vimeo,
      .embed--panopto {
        position: relative;
        padding-top: 56.25%; /* 16:9 */
        margin: 1.5em 0;
        background: var(--rule);
        border-radius: 4px;
        overflow: hidden;
      }

      .embed--youtube iframe,
      .embed--vimeo iframe,
      .embed--panopto iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
      }

      /* ---------- icon sprite + profile-icons ---------- */
      .icon-sprite {
        position: absolute;
        width: 0;
        height: 0;
        overflow: hidden;
      }

      .profile-icons {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-left: 0.25rem;
        vertical-align: -3px;
      }

      .profile-icons a,
      .profile-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--fg-muted);
        text-decoration: none;
        line-height: 1;
      }

      .profile-icons a:hover,
      .profile-link:hover {
        color: var(--accent);
        text-decoration: none;
      }

      .profile-icons a svg,
      .profile-link svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
      }

      /* ---------- main ---------- */
      .site-main {
        flex: 1;
        width: 100%;
        max-width: var(--measure);
        margin: 0 auto;
        padding: clamp(2rem, 6vw, 4rem) var(--gutter);
      }

      .site-main--wide {
        max-width: none;
        padding: 0;
      }

      .site-main > article > h1:first-child,
      .site-main > h1:first-child {
        margin-top: 0;
        font-size: clamp(2.4rem, 5.5vw, 3.5rem);
      }

      /* ---------- footer ---------- */
      .site-footer {
        padding: 0 0 1.75rem;
        color: var(--fg-muted);
        font-size: 0.875rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
      }

      .site-footer p {
        margin: 0;
      }

      .site-footer__note {
        max-width: 44rem;
        line-height: 1.55;
        padding: 0 var(--gutter);
      }

      .site-footer__hl {
        font-style: normal;
        background-image: linear-gradient(var(--accent-mustard), var(--accent-mustard));
        background-repeat: no-repeat;
        background-position: 0 90%;
        background-size: 100% 0.42em;
        padding: 0 0.12em;
        color: var(--fg);
        font-weight: 500;
      }


      /* ---------- a11y ---------- */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </body>
</html>
