---
import ColorStripe from "../components/ColorStripe.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  wide?: boolean;
}

const SITE_NAME = "sunelehmann.com";
const SITE_SUBTITLE = "intermittent updates";
const DEFAULT_DESCRIPTION =
  "Sune Lehmann — networks, complexity, and the occasional blog post.";
const DEFAULT_OG_IMAGE = "/og-image.jpg";

const {
  title,
  description = DEFAULT_DESCRIPTION,
  ogImage = DEFAULT_OG_IMAGE,
  noIndex = false,
  wide = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE_NAME}` : `${SITE_NAME} — ${SITE_SUBTITLE}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

const navLinks = [
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
  { href: "/featured-publications", label: "Featured publications" },
  { href: "/cv", label: "CV" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title ?? `${SITE_NAME} — ${SITE_SUBTITLE}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_NAME} — ${SITE_SUBTITLE}`}
      href="/rss.xml"
    />
  </head>

  <body>
    <header class="site-header">
      <a class="site-title" href="/">
        <span class="site-title__name">sune<span class="site-title__lehmann">lehmann</span>.com</span>
        <span class="site-title__sep" aria-hidden="true">—</span>
        <span class="site-title__subtitle">{SITE_SUBTITLE}</span>
      </a>
      <nav class="site-nav" aria-label="Main">
        <ul>
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={currentPath === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main class:list={["site-main", wide && "site-main--wide"]}>
      <slot />
    </main>

    <footer class="site-footer">
      <ColorStripe thickness="4px" />

      <p class="site-footer__note">
        This site (including the portraits of Sune) was generated by AI from a
        private database of old CV facts. The blog is the
        <em class="site-footer__hl">crucial exception</em>: each post has been
        painstakingly written by Sune himself, no AI involved.
        &copy; {new Date().getFullYear()} Sune Lehmann.
      </p>
    </footer>

    <style is:global>
      /* ---------- tokens ---------- */
      :root {
        --bg: #f6f2ea;
        --fg: #1a1814;
        --fg-muted: #6b655d;
        --rule: #e3ddd0;

        /* Six-color earth palette — bolder, saturated, sweeping warm→cool→warm
           (sienna → clay → mustard → olive → teal → oxblood). All still sit
           on the warm side; --accent is the primary. */
        --accent: #b8451e;          /* burnt sienna */
        --accent-clay: #d96a2c;     /* terracotta clay */
        --accent-mustard: #e8b126;  /* mustard ochre */
        --accent-olive: #7e8d20;    /* olive */
        --accent-teal: #107078;     /* deep teal */
        --accent-oxblood: #992c44;  /* oxblood wine */

        --serif: "Fraunces", "Palatino", Georgia, serif;
        --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;

        --measure: 36rem;
        --gutter: clamp(1rem, 4vw, 2.5rem);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f0e0c;
          --fg: #ede6d6;
          --fg-muted: #8a8377;
          --accent: #d4923a; /* placeholder; final amber-vs-teal pending */
          --rule: #1f1d18;
        }
      }

      /* ---------- reset ---------- */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
        font-size: 18px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }

      a:hover {
        text-decoration-thickness: 2px;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--serif);
        font-weight: 600;
        line-height: 1.1;
        letter-spacing: -0.015em;
        font-variation-settings: "opsz" 96;
      }

      /* ---------- header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 0.75rem var(--gutter);
        background: color-mix(in srgb, var(--bg) 92%, transparent);
        backdrop-filter: saturate(140%) blur(8px);
        border-bottom: 1px solid var(--rule);
      }

      .site-title {
        font-family: var(--serif);
        font-size: 1.65rem;
        text-decoration: none;
        color: var(--fg);
        white-space: nowrap;
        letter-spacing: -0.025em;
        font-variation-settings: "opsz" 48;
        line-height: 1;
      }

      .site-title__name {
        font-weight: 400;
      }

      .site-title__lehmann {
        font-weight: 700;
        font-style: italic;
      }

      .site-title__sep,
      .site-title__subtitle {
        color: var(--fg-muted);
        font-style: italic;
      }

      @media (max-width: 540px) {
        .site-title__sep,
        .site-title__subtitle {
          display: none;
        }
      }

      .site-nav ul {
        display: flex;
        gap: 1.25rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .site-nav a {
        color: var(--fg);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        color: var(--accent);
      }

      /* ---------- main ---------- */
      .site-main {
        flex: 1;
        width: 100%;
        max-width: var(--measure);
        margin: 0 auto;
        padding: clamp(2rem, 6vw, 4rem) var(--gutter);
      }

      .site-main--wide {
        max-width: none;
        padding: 0;
      }

      .site-main > article > h1:first-child,
      .site-main > h1:first-child {
        margin-top: 0;
        font-size: clamp(2.4rem, 5.5vw, 3.5rem);
      }

      /* ---------- footer ---------- */
      .site-footer {
        padding: 0 0 1.75rem;
        color: var(--fg-muted);
        font-size: 0.875rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
      }

      .site-footer p {
        margin: 0;
      }

      .site-footer__note {
        max-width: 44rem;
        line-height: 1.55;
        padding: 0 var(--gutter);
      }

      .site-footer__hl {
        font-style: normal;
        background-image: linear-gradient(var(--accent-mustard), var(--accent-mustard));
        background-repeat: no-repeat;
        background-position: 0 90%;
        background-size: 100% 0.42em;
        padding: 0 0.12em;
        color: var(--fg);
        font-weight: 500;
      }


      /* ---------- a11y ---------- */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </body>
</html>
