---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ColorStripe from "../components/ColorStripe.astro";

const PORTRAITS = [
  "astronaut",
  "beekeeper",
  "cowboy",
  "disco_dancer",
  "fireman",
  "mad_scientist",
  "samurai",
  "scuba_diver",
  "skinny_black_tie",
  "toreador",
];

const posts = (await getCollection("posts", ({ data }) => data.status === "publish"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = posts[0];
const recentPosts = posts.slice(1, 6);

function makeExcerpt(body: string, maxLen = 280): string {
  // Pick the first prose paragraph (skip image-only blocks).
  let para = "";
  for (const p of body.split(/\n\s*\n/)) {
    const cleaned = p.replace(/!\[[^\]]*\]\([^)]*\)/g, "").trim();
    if (cleaned.length > 20) {
      para = cleaned;
      break;
    }
  }
  const text = para
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
    .replace(/[*_~`]+/g, "")
    .replace(/^#+\s*/gm, "")
    .replace(/^>\s*/gm, "")
    .replace(/<[^>]+>/g, "")
    .replace(/\s+/g, " ")
    .trim();
  if (text.length <= maxLen) return text;
  const cut = text.slice(0, maxLen);
  const lastSpace = cut.lastIndexOf(" ");
  return (lastSpace > 60 ? cut.slice(0, lastSpace) : cut) + "…";
}

const featuredSlug = featured.data.slug ?? featured.id;
const featuredExcerpt = makeExcerpt(featured.body ?? "");
const featuredDate = featured.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout wide>
  <section class="hero" aria-label="Hero">
    <div class="hero__art" aria-hidden="true">
      <svg class="hero__network" viewBox="0 0 1000 200" preserveAspectRatio="xMidYMid meet"></svg>
    </div>

    <div class="hero__portrait-wrap">
      <img
        id="hero-portrait"
        class="hero__portrait"
        width="1254"
        height="1254"
        alt="Portrait of Sune Lehmann"
        decoding="async"
        data-portraits={PORTRAITS.join(",")}
      />
      <script is:inline>
        (function () {
          var img = document.getElementById("hero-portrait");
          var list = img.getAttribute("data-portraits").split(",");
          var pick = list[Math.floor(Math.random() * list.length)];
          img.src = "/photos/" + pick + ".jpg";
          img.dataset.portrait = pick;
        })();
      </script>
      <noscript>
        <style>#hero-portrait { display: none; }</style>
        <img class="hero__portrait" src="/photos/skinny_black_tie.jpg" alt="Portrait of Sune Lehmann" />
      </noscript>
    </div>
  </section>

  <script>
    import { select } from "d3-selection";
    import { forceSimulation, forceLink, forceManyBody, forceX, forceY } from "d3-force";
    import { drag } from "d3-drag";

    function buildNetwork() {
      const svg = document.querySelector(".hero__network");
      if (!svg) return;

      // viewBox units — 5:1 strip
      const W = 1000;
      const H = 200;
      const N = 100;
      const R = 0.4 * H;          // RGG connection radius (~0.4 of strip height)
      const NODE_R = 6.75;
      const PAD = NODE_R + 1;

      const css = getComputedStyle(document.documentElement);
      const PALETTE = [
        css.getPropertyValue("--accent").trim(),
        css.getPropertyValue("--accent-clay").trim(),
        css.getPropertyValue("--accent-mustard").trim(),
        css.getPropertyValue("--accent-olive").trim(),
        css.getPropertyValue("--accent-teal").trim(),
        css.getPropertyValue("--accent-oxblood").trim(),
      ];
      const MUTED = css.getPropertyValue("--fg-muted").trim() || "#6B655D";

      const nodes = Array.from({ length: N }, (_, i) => ({
        id: i,
        x: PAD + Math.random() * (W - 2 * PAD),
        y: PAD + Math.random() * (H - 2 * PAD),
      }));

      // Pin the leftmost and rightmost initial nodes as anchors so the layout
      // stretches across the 5:1 strip instead of collapsing into a circle and
      // pressing nodes against the side boundaries.
      const ANCHOR_INSET = 0.25 * H;
      let leftIdx = 0, rightIdx = 0;
      for (let i = 1; i < N; i++) {
        if (nodes[i].x < nodes[leftIdx].x) leftIdx = i;
        if (nodes[i].x > nodes[rightIdx].x) rightIdx = i;
      }
      nodes[leftIdx].fx = ANCHOR_INSET;
      nodes[leftIdx].fy = H / 2;
      nodes[rightIdx].fx = W - ANCHOR_INSET;
      nodes[rightIdx].fy = H / 2;

      const links = [];
      const R2 = R * R;
      for (let i = 0; i < N; i++) {
        for (let j = i + 1; j < N; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          if (dx * dx + dy * dy < R2) {
            links.push({ source: i, target: j });
          }
        }
      }

      const adj = Array.from({ length: N }, () => []);
      for (const l of links) {
        adj[l.source].push(l.target);
        adj[l.target].push(l.source);
      }

      // Find connected components and bridge any disconnected ones with a
      // single random link, so the network is always one piece.
      const componentOf = new Array(N).fill(-1);
      const components = [];
      for (let i = 0; i < N; i++) {
        if (componentOf[i] !== -1) continue;
        const comp = [];
        const stack = [i];
        componentOf[i] = components.length;
        while (stack.length) {
          const u = stack.pop();
          comp.push(u);
          for (const v of adj[u]) {
            if (componentOf[v] === -1) {
              componentOf[v] = components.length;
              stack.push(v);
            }
          }
        }
        components.push(comp);
      }
      if (components.length > 1) {
        components.sort((a, b) => b.length - a.length);
        const root = components[0];
        for (let i = 1; i < components.length; i++) {
          const comp = components[i];
          const u = comp[Math.floor(Math.random() * comp.length)];
          const v = root[Math.floor(Math.random() * root.length)];
          links.push({ source: u, target: v });
          adj[u].push(v);
          adj[v].push(u);
          for (const k of comp) root.push(k);
        }
      }

      // BFS shells from a random epicenter, before d3-force resolves link refs
      const epicenter = Math.floor(Math.random() * N);
      const dist = new Array(N).fill(-1);
      dist[epicenter] = 0;
      const queue = [epicenter];
      while (queue.length) {
        const u = queue.shift();
        for (const v of adj[u]) {
          if (dist[v] === -1) {
            dist[v] = dist[u] + 1;
            queue.push(v);
          }
        }
      }

      const colorFor = (d) => (d < 0 ? MUTED : PALETTE[d % PALETTE.length]);

      const svgSel = select(svg);
      svgSel.selectAll("*").remove();

      const linkSel = svgSel.append("g")
        .attr("class", "hero__network-links")
        .selectAll("line")
        .data(links)
        .join("line")
        .attr("stroke", (d) => colorFor(Math.min(dist[d.source], dist[d.target])))
        .attr("stroke-width", 0.9)
        .attr("stroke-opacity", 0.55)
        .attr("stroke-linecap", "round");

      const nodeSel = svgSel.append("g")
        .attr("class", "hero__network-nodes")
        .selectAll("circle")
        .data(nodes)
        .join("circle")
        .attr("r", (d) => (dist[d.id] < 0 ? NODE_R * 0.7 : NODE_R))
        .attr("fill", (d) => colorFor(dist[d.id]));

      const sim = forceSimulation(nodes)
        .force("link", forceLink(links).id((d) => d.id))
        .force("charge", forceManyBody().strength(-15))
        .force("compress-x", forceX(W / 2).strength(0.01))
        .force("compress-y", forceY(H / 2).strength(0.02))
        .alpha(0.9)
        .alphaDecay(0.025);

      // Make nodes draggable. Non-anchors release on drag end and the
      // simulation re-settles them; the two pinned anchors stay wherever
      // the user drops them.
      const anchorIds = new Set([leftIdx, rightIdx]);
      const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));
      nodeSel.call(
        drag()
          .on("start", (event, d) => {
            if (!event.active) sim.alphaTarget(0.3).restart();
            d.fx = d.x;
            d.fy = d.y;
          })
          .on("drag", (event, d) => {
            d.fx = clamp(event.x, PAD, W - PAD);
            d.fy = clamp(event.y, PAD, H - PAD);
          })
          .on("end", (event, d) => {
            if (!event.active) sim.alphaTarget(0);
            if (!anchorIds.has(d.id)) {
              d.fx = null;
              d.fy = null;
            }
          })
      );

      sim.on("tick", () => {
        for (const n of nodes) {
          if (n.x < PAD) n.x = PAD;
          else if (n.x > W - PAD) n.x = W - PAD;
          if (n.y < PAD) n.y = PAD;
          else if (n.y > H - PAD) n.y = H - PAD;
        }
        linkSel
          .attr("x1", (d) => d.source.x)
          .attr("y1", (d) => d.source.y)
          .attr("x2", (d) => d.target.x)
          .attr("y2", (d) => d.target.y);
        nodeSel.attr("cx", (d) => d.x).attr("cy", (d) => d.y);
      });

      svg.dataset.network = `n${N}-r${Math.round(R)}-e${epicenter}`;
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", buildNetwork);
    } else {
      buildNetwork();
    }
  </script>

  <ColorStripe
    thickness="6px"
    maxWidth="55.5rem"
    margin="clamp(0.75rem, 2vw, 1.25rem) auto 0"
  />

  <section class="landing">
    <p class="landing__bio">
      You have arrived at Sune Lehmann's site. I (Sune) am a Professor of
      Networks and Complexity Science at the Technical University of Denmark
      (DTU), and also a Professor of Social Data Science at the University of
      Copenhagen. A physicist by training, my research uses massive datasets
      and methods from complex systems, machine learning, and network science
      to understand human behavior — from how we move through cities to how
      information spreads online. I'm a member of the Royal Danish Academy of
      Sciences and Letters and Chief Scientist at the Danish National Center
      for AI in Society (CAISA).
    </p>

    <section class="landing__featured" aria-labelledby="featured-heading">
      <h2 id="featured-heading">Latest post</h2>
      <article class="featured-post">
        <ColorStripe thickness="4px" />
        <div class="featured-post__inner">
          <p class="featured-post__meta">
            <time datetime={featured.data.date.toISOString()}>{featuredDate}</time>
            {featured.data.categories.length > 0 && (
              <>
                <span class="featured-post__sep" aria-hidden="true">·</span>
                <span>{featured.data.categories.join(", ")}</span>
              </>
            )}
          </p>
          <h3 class="featured-post__title">
            <a href={`/blog/${featuredSlug}`}>{featured.data.title}</a>
          </h3>
          <p class="featured-post__excerpt">{featuredExcerpt}</p>
          <p class="featured-post__more">
            <a href={`/blog/${featuredSlug}`}>Read more →</a>
          </p>
        </div>
      </article>
    </section>

    <section class="landing__recent" aria-labelledby="recent-heading">
      <h2 id="recent-heading">Recent posts</h2>
      <ul class="post-list">
        {recentPosts.map((post) => {
          const slug = post.data.slug ?? post.id;
          return (
            <li>
              <a href={`/blog/${slug}`}>{post.data.title}</a>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </li>
          );
        })}
      </ul>
      <p class="landing__more">
        <a href="/blog">All posts ({posts.length}) →</a>
      </p>
    </section>
  </section>
</BaseLayout>

<style>
  .hero {
    width: 100%;
    max-width: 55.5rem;
    aspect-ratio: 6 / 1;
    min-height: 80px;
    margin: clamp(1rem, 3vw, 2rem) auto 0;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    overflow: hidden;
    background: var(--bg);
  }

  .hero__art {
    flex: 1 1 auto;
    display: block;
    min-width: 0;
    height: 100%;
  }

  .hero__network {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero__network circle {
    cursor: grab;
  }

  .hero__network circle:active {
    cursor: grabbing;
  }

  .hero__portrait-wrap {
    flex: none;
    aspect-ratio: 1 / 1;
    height: 100%;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
  }

  .hero__portrait {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: 18px;
  }

  .landing {
    max-width: var(--measure);
    margin: 0 auto;
    padding: clamp(1rem, 3vw, 2rem) var(--gutter) clamp(2rem, 6vw, 4rem);
  }

  .landing__bio {
    font-size: 1.05rem;
    margin: 0 0 3rem;
  }

  .landing__featured,
  .landing__recent {
    margin: 0 0 3rem;
  }

  .landing__featured h2,
  .landing__recent h2 {
    font-family: var(--sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg-muted);
    font-weight: 600;
    font-variation-settings: normal;
    margin: 0 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    line-height: 1;
  }

  .landing__featured h2::before,
  .landing__recent h2::before {
    content: "";
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
  }

  .landing__featured h2::before {
    background: var(--accent);
  }

  .landing__recent h2::before {
    background: var(--accent-olive);
  }

  .featured-post {
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border-radius: 6px;
    overflow: hidden;
  }

  .featured-post__inner {
    padding: 1.25rem 1.5rem 1.25rem;
  }

  .featured-post__meta {
    margin: 0 0 0.5rem;
    color: var(--fg-muted);
    font-size: 0.875rem;
    font-variant-numeric: tabular-nums;
  }

  .featured-post__sep {
    margin: 0 0.4em;
  }

  .featured-post__title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.6rem, 3vw, 2rem);
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 60;
    line-height: 1.15;
  }

  .featured-post__title a {
    color: var(--fg);
    text-decoration: none;
  }

  .featured-post__title a:hover {
    color: var(--accent);
  }

  .featured-post__excerpt {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
  }

  .featured-post__more {
    margin: 0;
    font-size: 0.95rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-list li {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    justify-content: space-between;
  }

  .post-list a {
    color: var(--fg);
    text-decoration: none;
    flex: 1;
  }

  .post-list a:hover {
    color: var(--accent);
  }

  .post-list time {
    color: var(--fg-muted);
    font-size: 0.875rem;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .landing__more {
    margin: 1rem 0 0;
    font-size: 0.95rem;
  }
</style>
